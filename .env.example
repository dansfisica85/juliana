# ============================================================
# Configuração do servidor — Juliana Balbino
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA cometa o .env real no git.
# ============================================================

# --- Turso / libSQL ---
TURSO_DATABASE_URL=libsql://example-user.aws-us-east-2.turso.io
TURSO_AUTH_TOKEN=coloque_aqui_seu_token_jwt_do_turso

# --- Autenticação ---
# Segredo usado para assinar os cookies JWT do admin.
# Gere um valor aleatório forte (ex: openssl rand -hex 48).
JWT_SECRET=troque_por_um_segredo_aleatorio_longo

# Credenciais iniciais do administrador (apenas no primeiro start).
# Depois disso, o login/senha podem ser alterados pelo painel.
ADMIN_INITIAL_USER=JulianaAdmin
ADMIN_INITIAL_PASSWORD=ModaeBemEstar2026#

# --- Pexels (opcional, para busca de imagens gratuitas) ---
# Crie em https://www.pexels.com/api/  (gratuito).
PEXELS_API_KEY=

# --- Servidor ---
PORT=3000
NODE_ENV=development
